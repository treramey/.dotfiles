{
  // open json editor for settings
  "workbench.settings.editor": "json",
  "workbench.iconTheme": "moxer-icons",
  // Change font
  "editor.fontFamily": "Input Nerd Font",
  "scm.inputFontFamily": "Input Nerd Font",
  "terminal.integrated.fontFamily": "Input Nerd Font",
  "chat.editor.fontFamily": "Input Nerd Font",
  "debug.console.fontFamily": "Input Nerd Font",
  "editor.codeLensFontFamily": "Input Nerd Font",
  "notebook.output.fontFamily": "Input Nerd Font",
  "markdown.preview.fontFamily": "Input Nerd Font",
  "editor.inlayHints.fontFamily": "Input Nerd Font",
  // Font size
  "editor.fontSize": 14,
  "editor.cursorSurroundingLines": 8,
  "terminal.integrated.fontSize": 14,
  // ui
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "auto",
  "editor.lineNumbers": "relative",
  "window.titleBarStyle": "custom",
  "editor.scrollbar.horizontal": "auto",
  "workbench.sideBar.location": "right",
  "errorLens.messageBackgroundMode": "message",
  // APC
  "apc.activityBar": {
    "position": "bottom",
    "hideSettings": false,
    "size": 28
  },
  "apc.electron": {
    "titleBarStyle": "hiddenInset",
    "trafficLightPosition": {
      "x": 12,
      "y": 10
    }
  },
  "apc.font.family": "Input Nerd Font",
  "apc.monospace.font.family": "Input Nerd Font",
  "apc.statusBar": {
    "position": "editor-bottom",
    "height": 28,
    "fontSize": 10
  },
  // Cusom css
  "apc.stylesheet": {
    ".sidebar > .composite": "height: 12px !important",
    ".title-label": "display: none !important",
    ".title-actions": "display: none !important",
    ".tabs-and-actions-container > .editor-actions": "display: none !important",
    ".titlebar-center": "display: none !important",
    ".titlebar-right": "display: none !important",
    ".inline-tabs-placeholder": "display: none !important",
    ".split-view-view .visible": "background-color: #24273a !important"
  },
  // Aura theme customisation
  "workbench.colorCustomizations": {
    "[poimandres]": {
      "editor.background": "#1b1d29",
      "terminal.background": "#1b1d29",
      "activityBar.background": "#1b1d29",
      "statusBar.background": "#1b1d29",
      "editorGroupHeader.tabsBackground": "#1b1d29",
      "tab.inactiveBackground": "#1b1d29"
    },
    "[Catppuccin Macchiato]": {
      "editor.background": "#24273a",
      "terminal.background": "#24273a",
      "activityBar.background": "#24273a",
      "statusBar.background": "#24273a",
      "editorGroupHeader.tabsBackground": "#24273a",
      "tab.inactiveBackground": "#24273a"
    }
  },
  // Toggle excluded files
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/.husky": true,
    "**/drizzle": true,
    "**/dist": true,
    "**/.todo.md": true,
    "**/.vscode": false,
    "**/.eslintrc.cjs": true,
    "**/.editorconfig": true,
    "**/.gitignore": true,
    "**/.lintstagedrc.mjs": true,
    "**/.markdownlint.json": true,
    "**/.markdownlintignore": true,
    "**/.prettierignore": true,
    "**/bun.lockb": true,
    "**/cspell.json": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/next-env.d.ts": true,
    "**/postcss.config.cjs": true,
    "**/prettier.config.js": true,
    "**/README.md": true,
    "**/next.config.js": true,
    "**/tailwind.config.ts": true,
    "**/drizzle.config.ts": true,
    "**/migrate.ts": true,
    "**/.env.example": true
  },
  // Misc
  "workbench.startupEditor": "none",
  "explorer.compactFolders": false,
  "editor.tabSize": 2,
  "editor.linkedEditing": true,
  "breadcrumbs.filePath": "off",
  "files.trimTrailingWhitespace": true,
  // Language specific settings
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },
  "[cfml]": {
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 120
  },
  "[inc]": {
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 120
  },
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "window.zoomLevel": 0.75,
  "editor.rulers": [120],
  //project manager
  "projectManager.sortList": "Recent",
  "projectManager.git.baseFolders": ["$home/dev"],
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  "vim.foldfix": true,
  "vim.highlightedyank.color": "rgba(230, 97, 89, 0.7)",
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.textColor": "white",
  "vim.hlsearch": true,
  "vim.useSystemClipboard": true,
  "vim.enableNeovim": true,
  "vim.leader": "<Space>",
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    // DEBUG
    {
      "before": ["<leader>", "d", "d"],
      "commands": ["workbench.action.debug.start"]
    },
    {
      "before": ["<leader>", "d", "S"],
      "commands": ["workbench.action.debug.stop"]
    },
    {
      "before": ["<leader>", "d", "c"],
      "commands": ["workbench.action.debug.continue"]
    },
    {
      "before": ["<leader>", "d", "p"],
      "commands": ["workbench.action.debug.pause"]
    },
    {
      "before": ["<leader>", "d", "r"],
      "commands": ["workbench.action.debug.run"]
    },
    {
      "before": ["<leader>", "d", "R"],
      "commands": ["workbench.action.debug.restart"]
    },
    {
      "before": ["<leader>", "d", "i"],
      "commands": ["workbench.action.debug.stepInto"]
    },
    {
      "before": ["<leader>", "d", "s"],
      "commands": ["workbench.action.debug.stepOver"]
    },
    {
      "before": ["<leader>", "d", "o"],
      "commands": ["workbench.action.debug.stepOut"]
    },
    {
      "before": ["<leader>", "d", "b"],
      "commands": ["editor.debug.action.toggleBreakpoint"]
    },
    {
      "before": ["<leader>", "d", "B"],
      "commands": ["editor.debug.action.toggleInlineBreakpoint"]
    },
    {
      "before": ["<leader>", "d", "j"],
      "commands": ["debug.jumpToCursor"]
    },
    {
      "before": ["<leader>", "d", "v"],
      "commands": ["workbench.debug.action.toggleRepl"]
    },
    {
      "before": ["<leader>", "d", "w"],
      "commands": ["workbench.debug.action.focusWatchView"]
    },
    {
      "before": ["<leader>", "d", "W"],
      "commands": ["editor.debug.action.selectionToWatch"]
    },
    // NAVIGATION
    {
      "before": ["<C-[>"],
      "commands": [":bprevious"]
    },
    {
      "before": ["<C-]>"],
      "commands": [":bnext"]
    },
    {
      "before": ["leader", "r"],
      "commands": ["editor.action.rename"]
    },
    // splits
    {
      "before": ["leader", "v"],
      "commands": [":vsplit"]
    },
    {
      "before": ["leader", "s"],
      "commands": [":split"]
    },
    // NICE TO HAVE
    {
      "before": ["U"],
      "after": ["<C-r>"]
    },
    {
      "after": ["^"],
      "before": ["H"]
    },
    {
      "after": ["$"],
      "before": ["L"]
    },
    {
      "before": ["leader", "d"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["leader", "w"],
      "commands": [":w!"]
    },
    {
      "before": ["leader", "q"],
      "commands": [":q!"]
    },
    {
      "before": ["leader", "x"],
      "commands": [":x!"]
    },
    {
      "before": ["[", "d"],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["]", "d"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["leader", "s", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "s", "g"],
      "commands": ["find-it-faster.findWithinFiles"]
    },
    {
      "before": ["leader", "f"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["g", "h"],
      "commands": ["editor.action.showDefinitionPreviewHover"]
    }
  ],
  "vim.visualModeKeyBindings": [
    // Stay in visual mode while indenting
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    },
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    // Move selected lines while staying in visual mode
    {
      "before": ["J"],
      "commands": ["editor.action.moveLinesDownAction"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.moveLinesUpAction"]
    },
    // toggle comment selection
    {
      "before": ["leader", "c"],
      "commands": ["editor.action.commentLine"]
    }
  ],
  "cSpell.userWords": [],
  "cSpell.customDictionaries": {
    "custom-dictionary-user": {
      "name": "custom-dictionary-user",
      "path": "~/.cspell/custom-dictionary-user.txt",
      "addWords": true,
      "scope": "user"
    }
  },
  "cSpell.ignoreWords": ["neovim", "whichkey"],
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "files.associations": {
    ".cflintrc": "json",
    "*.inc": "cfml"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "auto-close-tag.excludedTags": [
    "area",
    "base",
    "br",
    "col",
    "command",
    "embed",
    "hr",
    "img",
    "input",
    "keygen",
    "link",
    "meta",
    "param",
    "source",
    "track",
    "wbr",
    "cfabort",
    "cfapplication",
    "cfargument",
    "cfassociate",
    "cfbreak",
    "cfchartdata",
    "cfcollection",
    "cfcontent",
    "cfcontinue",
    "cfcookie",
    "cfdirectory",
    "cfdump",
    "cfelse",
    "cfelseif",
    "cferror",
    "cfexecute",
    "cfexit",
    "cffile",
    "cfflush",
    "cfheader",
    "cfhttpparam",
    "cfimage",
    "cfimport",
    "cfinclude",
    "cfindex",
    "cfinput",
    "cfinvokeargument",
    "cflocation",
    "cflog",
    "cfloginuser",
    "cflogout",
    "cfmailparam",
    "cfobject",
    "cfobjectcache",
    "cfparam",
    "cfpop",
    "cfprocessingdirective",
    "cfprocparam",
    "cfprocresult",
    "cfproperty",
    "cfqueryparam",
    "cfregistry",
    "cfreportparam",
    "cfrethrow",
    "cfreturn",
    "cfschedule",
    "cfspreadsheet",
    "cfsearch",
    "cfset",
    "cfsetting",
    "cfthrow",
    "cfwddx"
  ],
  "cflint.jarPath": "/Users/TRamey/dev/CFLint-1.5.0-all.jar",
  "workbench.colorTheme": "Catppuccin Macchiato",
  "window.commandCenter": false
}
