#!/usr/bin/env bash

set -euo pipefail

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly RESET='\033[0m'
readonly BOLD='\033[1m'

# Metadata
readonly SCRIPT_NAME="dot"
readonly VERSION="3.0.0"
DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly DOTFILES_DIR

# Platform detection
OS="$(uname -s)"
readonly OS
is_macos() { [[ "$OS" == "Darwin" ]]; }
is_arch() { [[ "$OS" == "Linux" ]] && [[ -f /etc/arch-release ]]; }

# ─── Helpers ─────────────────────────────────────────────────────────────────

print_header()  { echo -e "\n${BOLD}${BLUE}==>${RESET} ${BOLD}$1${RESET}"; }
print_success() { echo -e "${GREEN}✓${RESET} $1"; }
print_error()   { echo -e "${RED}✗${RESET} $1" >&2; }
print_warning() { echo -e "${YELLOW}⚠${RESET} $1"; }
print_info()    { echo -e "${CYAN}ℹ${RESET} $1"; }

command_exists() { command -v "$1" >/dev/null 2>&1; }

confirm() {
    local prompt="${1:-Continue?}" default="${2:-n}"
    if [[ "$default" == "y" ]]; then prompt="$prompt [Y/n]: "; else prompt="$prompt [y/N]: "; fi
    read -r -p "$prompt" response
    case "$response" in
        [yY][eE][sS]|[yY]) return 0 ;;
        [nN][oO]|[nN]) return 1 ;;
        "") [[ "$default" == "y" ]] && return 0 || return 1 ;;
        *) return 1 ;;
    esac
}

# ─── Chezmoi ─────────────────────────────────────────────────────────────────

_ensure_chezmoi() {
    if command_exists chezmoi; then return 0; fi

    print_info "Installing chezmoi..."
    sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "${HOME}/.local/bin" || {
        print_error "Failed to install chezmoi"
        return 1
    }
    export PATH="${HOME}/.local/bin:${PATH}"
    print_success "chezmoi installed"
}

# ─── macOS-specific ──────────────────────────────────────────────────────────

_install_homebrew() {
    if command_exists brew; then
        print_success "Homebrew is already installed"
        return 0
    fi

    print_info "Installing Homebrew..."
    if NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
        print_success "Homebrew installed"
        if [[ "$(uname -m)" == "arm64" ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        else
            eval "$(/usr/local/bin/brew shellenv)"
        fi
        brew analytics off
    else
        print_error "Homebrew installation failed"
        return 1
    fi
}

_install_packages() {
    if [[ ! -f "${DOTFILES_DIR}/Brewfile" ]]; then
        print_error "Brewfile not found"
        return 1
    fi

    print_info "Installing packages from Brewfile..."
    if brew bundle --file="${DOTFILES_DIR}/Brewfile"; then
        print_success "All packages installed"
    else
        print_warning "Some packages failed, trying individually..."
        local failed=()
        local count=0

        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line// }" ]] && continue

            if [[ "$line" =~ ^brew[[:space:]]+\"([^\"]+)\" ]]; then
                local pkg="${BASH_REMATCH[1]}"
                if brew install "$pkg" 2>/dev/null; then ((++count)); else failed+=("brew:$pkg"); fi
            elif [[ "$line" =~ ^cask[[:space:]]+\"([^\"]+)\" ]]; then
                local pkg="${BASH_REMATCH[1]}"
                if brew install --cask "$pkg" 2>/dev/null; then ((++count)); else failed+=("cask:$pkg"); fi
            fi
        done < "${DOTFILES_DIR}/Brewfile"

        if [[ ${#failed[@]} -gt 0 ]]; then
            print_warning "Failed to install ${#failed[@]} packages:"
            printf "  - %s\n" "${failed[@]}"
            printf "%s\n" "${failed[@]}" > "${DOTFILES_DIR}/failed_packages_$(date +%Y%m%d_%H%M%S).txt"
        fi
        print_success "Installed $count packages"
    fi
}

_set_macos_defaults() {
    print_info "Setting macOS defaults..."
    defaults write -g NSWindowShouldDragOnGesture -bool true
    defaults write -g NSAutomaticWindowAnimationsEnabled -bool false
    print_success "macOS defaults set"
}

_start_services() {
    print_info "Starting services..."
    if command_exists skhd; then
        brew services start skhd 2>/dev/null || true
        print_success "skhd started"
    else
        print_warning "skhd not found, skipping"
    fi
}

_build_bat_cache() {
    if ! command_exists bat; then
        print_warning "bat not installed, skipping cache build"
        return 0
    fi
    print_info "Building bat theme cache..."
    bat cache --build
    print_success "Bat cache built"
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_init() {
    print_header "Initializing dotfiles"

    # Install chezmoi
    _ensure_chezmoi || return 1

    # macOS: Homebrew + packages
    if is_macos; then
        print_header "Setting up macOS"
        _install_homebrew || return 1
        _install_packages || return 1
    fi

    # Arch: install watchman if missing
    if is_arch && ! command_exists watchman; then
        print_info "Installing watchman..."
        if command_exists yay; then
            yay -S --noconfirm watchman-bin && print_success "watchman installed" || print_warning "Failed to install watchman (continuing)"
        else
            print_warning "yay not found, skipping watchman install"
        fi
    fi

    # Apply dotfiles
    print_header "Applying dotfiles"
    print_info "Initializing chezmoi config..."
    if chezmoi init --source "${DOTFILES_DIR}" --apply=false; then
        print_success "chezmoi config initialized"
    else
        print_error "Failed to initialize chezmoi config"
        return 1
    fi
    print_info "Applying dotfiles with chezmoi..."
    if chezmoi apply --source "${DOTFILES_DIR}"; then
        print_success "Dotfiles applied successfully"
    else
        print_error "Failed to apply dotfiles"
        return 1
    fi

    # macOS post-setup
    if is_macos; then
        if confirm "Set macOS defaults?" "y"; then
            _set_macos_defaults
        fi
        _start_services
    fi

    _build_bat_cache

    print_header "Done!"
    print_info "Restart your shell or run: exec fish"
}

cmd_apply() {
    print_header "Applying dotfiles"

    _ensure_chezmoi || return 1

    # Regenerate config from template so data variables (e.g. is_arch) are available
    chezmoi init --source "${DOTFILES_DIR}" --apply=false || return 1

    # Clear cached state so chezmoi re-evaluates all files,
    # ensuring externally modified targets (e.g. fisher) get overwritten
    chezmoi state delete-bucket --bucket=entryState 2>/dev/null || true

    print_info "Applying dotfiles with chezmoi..."
    if chezmoi apply --force --source "${DOTFILES_DIR}" "$@"; then
        print_success "Dotfiles applied successfully"
    else
        print_error "Failed to apply dotfiles"
        return 1
    fi
}

cmd_update() {
    print_header "Updating dotfiles"

    # Pull latest
    print_info "Pulling latest changes..."
    if [[ -d "${DOTFILES_DIR}/.jj" ]] && command_exists jj; then
        if jj git fetch -R "$DOTFILES_DIR" && jj -R "$DOTFILES_DIR" rebase -d 'trunk()'; then
            print_success "Updated via jj"
        else
            print_error "Failed to update via jj"
            return 1
        fi
    elif git -C "$DOTFILES_DIR" pull; then
        print_success "Repository updated"
    else
        print_error "Failed to pull"
        return 1
    fi

    # macOS: update Homebrew packages
    if is_macos; then
        if confirm "Update Homebrew packages?" "y"; then
            print_info "Updating Homebrew..."
            brew update && brew upgrade
            print_success "Packages updated"
        fi
    fi

    # Re-apply
    if confirm "Re-apply dotfiles?" "y"; then
        cmd_apply
    fi
}

cmd_diff() {
    _ensure_chezmoi || return 1
    chezmoi diff --source "${DOTFILES_DIR}" "$@"
}

cmd_add() {
    _ensure_chezmoi || return 1
    chezmoi add --source "${DOTFILES_DIR}" "$@"
}

cmd_cd() {
    _ensure_chezmoi || return 1
    chezmoi cd --source "${DOTFILES_DIR}"
}

cmd_managed() {
    _ensure_chezmoi || return 1
    chezmoi managed --source "${DOTFILES_DIR}" "$@"
}

cmd_status() {
    _ensure_chezmoi || return 1
    chezmoi status --source "${DOTFILES_DIR}" "$@"
}

cmd_doctor() {
    print_header "Running diagnostics"
    local issues=0

    # chezmoi
    if command_exists chezmoi; then
        print_success "chezmoi installed ($(chezmoi --version 2>/dev/null | head -1))"
    else
        print_error "chezmoi not installed"
        ((++issues))
    fi

    # Platform-specific
    if is_macos; then
        if command_exists brew; then print_success "Homebrew installed"; else print_error "Homebrew not installed"; ((++issues)); fi
    elif is_arch; then
        if command_exists pacman; then print_success "pacman available"; else print_error "pacman not found"; ((++issues)); fi
        if command_exists yay; then print_success "yay available"; else print_warning "yay not installed"; fi
    fi

    # Shell
    local zsh_path
    zsh_path=$(command -v zsh 2>/dev/null || true)
    if [[ -n "$zsh_path" ]]; then
        print_success "Zsh installed"
        if [[ "$SHELL" == "$zsh_path" ]]; then
            print_success "Zsh is default shell"
        else
            print_warning "Zsh is not default shell (current: $SHELL)"
        fi
    else
        print_error "Zsh not installed"
        ((++issues))
    fi

    # Dev tools
    local tools=("git" "nvim" "tmux" "node")
    local missing=()
    for tool in "${tools[@]}"; do
        if command_exists "$tool"; then print_success "$tool available"; else missing+=("$tool"); fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        print_warning "Missing tools: ${missing[*]}"
    fi

    # jj
    if command_exists jj; then
        print_success "jj (Jujutsu) installed"
    else
        print_warning "jj not installed"
    fi

    # chezmoi doctor
    if command_exists chezmoi; then
        print_header "chezmoi doctor"
        chezmoi doctor || true
    fi

    if [[ $issues -eq 0 ]]; then
        print_header "All critical checks passed!"
    else
        print_header "Found $issues critical issues"
    fi
}

cmd_edit() {
    if [[ $# -gt 0 ]]; then
        _ensure_chezmoi || return 1
        chezmoi edit --source "${DOTFILES_DIR}" "$@"
    else
        local editor="${EDITOR:-nvim}"
        if command_exists "$editor"; then
            exec "$editor" "$DOTFILES_DIR"
        else
            print_error "Editor '$editor' not found"
            return 1
        fi
    fi
}

cmd_watch() {
    _ensure_chezmoi || return 1

    if ! command_exists watchman; then
        print_error "watchman is not installed"
        if is_macos; then
            print_info "Install with: brew install watchman"
        elif is_arch; then
            print_info "Install with: yay -S watchman-bin"
        fi
        return 1
    fi

    local source_path
    source_path="$(chezmoi source-path --source "${DOTFILES_DIR}")"

    case "${1:-start}" in
        start)
            print_header "Starting file watcher"
            watchman watch "${source_path}"
            watchman trigger-del "${source_path}" chezmoi-apply 2>/dev/null || true
            watchman -j <<EOT
["trigger", "${source_path}", {
  "name": "chezmoi-apply",
  "command": ["chezmoi", "apply", "--force", "--source", "${DOTFILES_DIR}"]
}]
EOT
            print_success "Watching ${source_path} for changes"
            print_info "Changes will auto-apply. Run 'dot watch stop' to disable."
            ;;
        stop)
            print_header "Stopping file watcher"
            watchman watch-del "${source_path}" 2>/dev/null || true
            print_success "Watcher stopped"
            ;;
        status)
            if watchman watch-list 2>/dev/null | grep -q "${source_path}"; then
                print_success "Watcher is active on ${source_path}"
            else
                print_warning "Watcher is not running"
            fi
            ;;
        *)
            print_error "Unknown watch subcommand: $1"
            echo "Usage: dot watch [start|stop|status]"
            return 1
            ;;
    esac
}

cmd_help() {
    echo -e "${BOLD}${SCRIPT_NAME}${RESET} - Dotfiles management tool (v${VERSION})"
    echo ""
    echo -e "${BOLD}USAGE:${RESET}"
    echo "    ${SCRIPT_NAME} [OPTIONS] COMMAND [ARGS]"
    echo ""
    echo -e "${BOLD}COMMANDS:${RESET}"
    echo "    init            Initialize and install everything"
    echo "    apply [path]    Apply dotfiles with chezmoi"
    echo "    update          Pull changes, update packages, re-apply"
    echo "    diff            Preview pending changes"
    echo "    status          Show what's out of sync"
    echo "    add <file>      Add a file to the source state"
    echo "    edit [target]   Edit a target file, or open dotfiles dir"
    echo "    managed         List all managed files"
    echo "    cd              Open a shell in the source directory"
    echo "    watch [cmd]     Auto-apply on changes (start|stop|status)"
    echo "    doctor          Run diagnostics"
    echo "    help            Show this help"
    echo ""
    echo -e "${BOLD}OPTIONS:${RESET}"
    echo "    --version       Show version"
    echo "    -h, --help      Show help"
    echo ""
    echo -e "${BOLD}CONFIGURATION:${RESET}"
    echo "    Dotfiles: ${DOTFILES_DIR}"
    echo "    Platform: $(is_macos && echo "macOS" || (is_arch && echo "Arch Linux" || echo "Linux"))"
    echo ""
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --version) echo "${SCRIPT_NAME} v${VERSION}"; exit 0 ;;
            -h|--help) cmd_help; exit 0 ;;
            *) break ;;
        esac
    done

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        init)    cmd_init "$@" ;;
        apply)   cmd_apply "$@" ;;
        update)  cmd_update "$@" ;;
        diff)    cmd_diff "$@" ;;
        status)  cmd_status "$@" ;;
        add)     cmd_add "$@" ;;
        edit)    cmd_edit "$@" ;;
        managed) cmd_managed "$@" ;;
        cd)      cmd_cd "$@" ;;
        watch)   cmd_watch "$@" ;;
        doctor)  cmd_doctor "$@" ;;
        help)    cmd_help ;;
        *)
            print_error "Unknown command: $cmd"
            echo "Run '${SCRIPT_NAME} help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
