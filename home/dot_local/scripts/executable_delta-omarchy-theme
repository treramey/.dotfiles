#!/bin/bash
set -euo pipefail

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
theme_dir="$config_home/omarchy/current/theme"
delta_config="$config_home/delta/system.gitconfig"

if [[ ! -f "$delta_config" ]]; then
  exit 0
fi

feature="system-dark"
if [[ -f "$theme_dir/light.mode" ]]; then
  feature="system-light"
fi

git config --file "$delta_config" delta.features "$feature"
