    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.envrc)",
      "Read(secrets/*)",
      "Read(~/.ssh/**)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "Bash(kill -9:*)",
      "Bash(killall:*)",
