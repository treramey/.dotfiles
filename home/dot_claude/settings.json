    "additionalDirectories": [
      "/Users/TRamey/.dotfiles/",
      "/Users/TRamey/workspace/",
      "/Users/TRamey/dev/"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {},
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolUse/add_plan_frontmatter.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/UserPromptSubmit/log_prompts.py"
          }
        ]
      }
    ]
  }
}
