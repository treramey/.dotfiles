      "Skill(to-issues)",
      "Skill(to-prd)",
      "Skill(triage)",
      "Skill(write-a-skill)",
      "Skill(zoom-out)",
      "mcp__context7",
      "mcp__filesystem",
      "mcp__sequential-thinking",
      "mcp__serena"
