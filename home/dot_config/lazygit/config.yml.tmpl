{{ if (index . "is_omarchy" | default false) -}}
gui:
  showNumstatInFilesView: true
  skipRewordInEditorWarning: true
  tabWidth: 2
  border: single
  spinner:
    frames:
      - "⠋"
      - "⠙"
      - "⠹"
      - "⠸"
      - "⠼"
      - "⠴"
      - "⠦"
      - "⠧"
      - "⠇"
      - "⠏"
    rate: 80
  theme:
    # Omarchy/system: ANSI names only, so Ghostty's active palette controls the colors.
    activeBorderColor:
      - yellow
      - bold
    inactiveBorderColor:
      - default
    searchingActiveBorderColor:
      - cyan
      - bold
    optionsTextColor:
      - blue
    selectedLineBgColor:
      - blue
    inactiveViewSelectedLineBgColor:
      - default
      - bold
    cherryPickedCommitFgColor:
      - yellow
    cherryPickedCommitBgColor:
      - default
    markedBaseCommitFgColor:
      - yellow
    markedBaseCommitBgColor:
      - default
    unstagedChangesColor:
      - red
    defaultFgColor:
      - default
  authorColors:
    "*": cyan
  nerdFontsVersion: "3"
  switchTabsWithPanelJumpKeys: true
os:
  edit: "~/.local/scripts/tmux-nvim-open {{ "{{" }}filename{{ "}}" }}"
  editAtLineAndWait: "~/.local/scripts/tmux-nvim-open {{ "{{" }}filename{{ "}}" }}:{{ "{{" }}line{{ "}}" }}"
  editInTerminal: false
git:
  overrideGpg: true
  pagers:
    - colorArg: always
      pager: delta --paging=never
{{ else -}}
gui:
  showNumstatInFilesView: true
  skipRewordInEditorWarning: true
  tabWidth: 2
  border: single
  spinner:
    frames:
      - "⠋"
      - "⠙"
      - "⠹"
      - "⠸"
      - "⠼"
      - "⠴"
      - "⠦"
      - "⠧"
      - "⠇"
      - "⠏"
    rate: 80
  theme:
    activeBorderColor:
      - "#fab387"
      - bold
    inactiveBorderColor:
      - "#7f849c"
    searchingActiveBorderColor:
      - "#f9e2af"
    optionsTextColor:
      - "#89b4fa"
    selectedLineBgColor:
      - "#313244"
    inactiveViewSelectedLineBgColor:
      - bold
    cherryPickedCommitFgColor:
      - "#fab387"
    cherryPickedCommitBgColor:
      - "#45475a"
    markedBaseCommitFgColor:
      - "#fab387"
    markedBaseCommitBgColor:
      - "#45475a"
    unstagedChangesColor:
      - "#f38ba8"
    defaultFgColor:
      - "#bac2de" # '#cdd6f4'
  authorColors:
    "*": "#b4befe"
  nerdFontsVersion: "3"
  switchTabsWithPanelJumpKeys: true
os:
  edit: "~/.local/scripts/tmux-nvim-open {{ "{{" }}filename{{ "}}" }}"
  editAtLineAndWait: "~/.local/scripts/tmux-nvim-open {{ "{{" }}filename{{ "}}" }}:{{ "{{" }}line{{ "}}" }}"
  editInTerminal: false
git:
  overrideGpg: true
  pagers:
    - colorArg: always
      pager: delta --dark --paging=never
{{ end -}}
