#!/bin/bash
set -euo pipefail

# Omarchy calls this hook with the new theme's name on every theme switch.
# One adapter per tool, all inline; runtime state lands only in ~/.cache so
# chezmoi-managed configs never drift.

theme_name="${1:?usage: theme-set <omarchy-theme-name>}"
config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
theme_dir="$config_home/omarchy/current/theme"

mkdir -p ~/.cache

# nvim: theme_switcher.lua watches this file and swaps the colorscheme live.
echo "$theme_name" > ~/.cache/nvim-theme-trigger

# delta: git config includes this cache file after delta/system.gitconfig,
# so the light/dark feature selection follows the active theme.
feature="system-dark"
if [[ -f "$theme_dir/light.mode" ]]; then
  feature="system-light"
fi
git config --file ~/.cache/delta-features.gitconfig delta.features "$feature"
